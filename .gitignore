# ============================================
# ENVIRONMENT & CONFIGURATION
# ============================================
# Environment variables (SENSITIVE - never commit)
.env
.env.local
.env.*.local
.env.development.local
.env.test.local
.env.production.local

# ============================================
# DEPENDENCIES
# ============================================
# Node.js modules (reinstall with npm install)
node_modules/
package-lock.json

# ============================================
# RUNTIME LOGS & OUTPUT
# ============================================
# Application logs
*.log
logs/
*.lof
app.log
error.log
access.log

# npm logs
npm-debug.log*
npm-err.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# ============================================
# WHATSAPP SESSIONS & CREDENTIALS
# ============================================
# WhatsApp session data (sensitive - contains credentials & keys)
whatsapp-sessions/
session-*/

# ============================================
# TEMPORARY & GENERATED FILES
# ============================================
# Temporary uploads and generated files
public/uploads/*
public/temp/*
public/dist/

# Build outputs
dist/
build/
.next/
.nuxt/

# Cache directories
.cache/
.parcel-cache/
.eslintcache

# ============================================
# IDE & EDITOR
# ============================================
# VSCode
.vscode/
.vscode-settings.json

# IntelliJ IDEA
.idea/
*.iml
*.iws
*.ipr

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim & Nano
*.swp
*.swo
*~
.vim/

# Emacs
*~
\#*\#
.\#*

# C9 IDE
.c9/

# Webstorm
.webstorm.xml

