====================================================================
WA GATEWAY v3.5 - KONFIGURASI ENVIRONMENT
Salin file ini menjadi .env dan isi semua nilainya.
====================================================================
-- Konfigurasi Server Dasar --
PORT=3000

URL publik lengkap aplikasi Anda (PENTING untuk callback Google OAuth)
BASE_URL=https://wa.domain-anda.com

Kunci rahasia untuk enkripsi sesi login (buat dengan string acak yang panjang)
SESSION_SECRET=ganti_dengan_kunci_rahasia_acak_yang_panjang

-- Konfigurasi Database --
Nama file untuk database SQLite
DB_STORAGE=whatsapp_gateway.sqlite

-- Konfigurasi Autentikasi Google --
Dapatkan dari Google Cloud Console (https://console.cloud.google.com/)
GOOGLE_CLIENT_ID=https://www.google.com/search?q=xxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxx

-- Manajemen Pengguna & Admin --
Daftar email yang akan otomatis menjadi admin (pisahkan dengan koma)
ADMIN_EMAILS=admin1@gmail.com,admin2@yahoo.com

Info kontak admin yang akan ditampilkan di halaman login dan dashboard
ADMIN_CONTACT_INFO="WA: 081234567890"

-- Konfigurasi Keamanan & API --
Kunci rahasia 32 KARAKTER untuk enkripsi data di database (API Key, Webhook, dll.)
Anda bisa membuatnya di https://www.random.org/strings/
ENCRYPTION_KEY=BuatKunciRahasiaAcak32Karakter

-- Konfigurasi Default untuk Upload Media --
Pengaturan ini digunakan jika tidak ada pengaturan spesifik di setiap sesi
Batas ukuran file upload default (dalam MB)
UPLOAD_MAX_SIZE_MB=15

Tipe file yang diizinkan secara default (pisahkan dengan koma, tanpa spasi)
UPLOAD_ALLOWED_MIMETYPES="image/jpeg,image/png,application/pdf,video/mp4,audio/mpeg"

-- Konfigurasi Rate Limiter (Anti-Serangan) --
Jumlah permintaan maksimal dari satu IP dalam jendela waktu
API_RATE_LIMIT_MAX_REQUESTS=100

Jendela waktu untuk rate limit (dalam menit)
API_RATE_LIMIT_WINDOW_MIN=15

-- Konfigurasi Webhook (Opsional) --
URL webhook global (digunakan jika URL di pengaturan sesi kosong)
N8N_WEBHOOK_URL=

Alamat server database PostgreSQL Anda.
DB_HOST="172.18.0.2"
DB_PORT="5432"
DB_USER="dbuser"
DB_PASSWORD="dbpass"
DB_NAME="dbwa"