<!DOCTYPE html>
<html lang="id" data-theme="wabot">
<head>
  <%- include('partials/core/head', { title: 'Admin Dashboard' }) %>
</head>
<body class="bg-base-200 min-h-screen">
<div class="drawer lg:drawer-open">
  <input id="app-drawer" type="checkbox" class="drawer-toggle" />

  <div class="drawer-content flex flex-col min-h-screen">
    <%- include('partials/nav/topbar-app') %>

    <main class="flex-1 max-w-6xl mx-auto w-full px-4 sm:px-6 py-6">
      <%- include('partials/core/flash-alert') %>
      <%- include('partials/core/page-header', {
        pageTitle: 'Admin Dashboard',
        pageSubtitle: 'Kontrol dan monitoring seluruh sistem.'
      }) %>

      <!-- KPI Global -->
      <%- include('partials/dashboard-admin/kpi-cards') %>

      <!-- System health + recent users -->
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mt-6">
        <div class="lg:col-span-2">
          <%- include('partials/dashboard-admin/system-health') %>
        </div>
        <div>
          <%- include('partials/dashboard-admin/admin-actions') %>
        </div>
      </div>

      <!-- Recent users + audit feed -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mt-6">
        <%- include('partials/dashboard-admin/recent-users') %>
        <%- include('partials/dashboard-admin/audit-feed') %>
      </div>
    </main>
  </div>

  <div class="drawer-side z-40">
    <label for="app-drawer" aria-label="close sidebar" class="drawer-overlay"></label>
    <%- include('partials/nav/sidebar-admin') %>
  </div>
</div>
<%- include('partials/core/scripts', { loadSocketIO: true }) %>
</body>
</html>
