<%# dashboard-admin/audit-feed.ejs %>
<%# Variabel: auditLogs (array of {action, user, time, ip}) — opsional %>
<div class="card bg-base-100 border border-base-300/70 shadow-sm">
  <div class="card-body p-5">
    <div class="flex items-center justify-between mb-4">
      <h3 class="font-semibold text-base-content">Audit Feed</h3>
      <a href="/admin/logs" class="btn btn-ghost btn-xs gap-1 text-brand-600">
        Lihat log <i data-lucide="arrow-right" class="w-3.5 h-3.5"></i>
      </a>
    </div>
    <% if (typeof auditLogs !== 'undefined' && auditLogs.length > 0) { %>
    <ul class="space-y-3">
      <% auditLogs.slice(0,6).forEach(log => { %>
      <li class="flex items-start gap-3">
        <div class="bg-base-200 rounded-full p-1 shrink-0 mt-0.5">
          <i data-lucide="activity" class="w-3.5 h-3.5 text-base-content/40"></i>
        </div>
        <div class="flex-1 min-w-0">
          <p class="text-sm text-base-content/80"><span class="font-medium"><%= log.user %></span> — <%= log.action %></p>
          <p class="text-xs text-base-content/40"><%= log.time %><% if (log.ip) { %> · <%= log.ip %><% } %></p>
        </div>
      </li>
      <% }) %>
    </ul>
    <% } else { %>
    <%- include('../core/empty-state', { emptyIcon: 'scroll-text', emptyTitle: 'Belum ada log', emptyDesc: '' }) %>
    <% } %>
  </div>
</div>
