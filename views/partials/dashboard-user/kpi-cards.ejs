<%# dashboard-user/kpi-cards.ejs %>
<%# Variabel dari controller: sessions (array), totalMessages, failedMessages %>
<div class="grid grid-cols-2 lg:grid-cols-4 gap-4">

  <div class="card bg-base-100 border border-base-300/70 shadow-sm">
    <div class="card-body p-4">
      <div class="flex items-center justify-between mb-2">
        <span class="text-xs font-medium text-base-content/50 uppercase tracking-wide">Device Aktif</span>
        <div class="bg-success/10 rounded-lg p-1.5"><i data-lucide="smartphone" class="w-4 h-4 text-success"></i></div>
      </div>
      <p class="text-2xl font-bold text-base-content">
        <%= typeof sessions !== 'undefined' ? sessions.filter(s => s.status === 'connected').length : 0 %>
      </p>
      <p class="text-xs text-base-content/40 mt-1">dari <%= typeof sessions !== 'undefined' ? sessions.length : 0 %> total device</p>
    </div>
  </div>

  <div class="card bg-base-100 border border-base-300/70 shadow-sm">
    <div class="card-body p-4">
      <div class="flex items-center justify-between mb-2">
        <span class="text-xs font-medium text-base-content/50 uppercase tracking-wide">Pesan Hari Ini</span>
        <div class="bg-brand-50 rounded-lg p-1.5"><i data-lucide="message-square" class="w-4 h-4 text-brand-600"></i></div>
      </div>
      <p class="text-2xl font-bold text-base-content">
        <%= typeof totalMessages !== 'undefined' ? totalMessages : '—' %>
      </p>
      <p class="text-xs text-base-content/40 mt-1">terkirim hari ini</p>
    </div>
  </div>

  <div class="card bg-base-100 border border-base-300/70 shadow-sm">
    <div class="card-body p-4">
      <div class="flex items-center justify-between mb-2">
        <span class="text-xs font-medium text-base-content/50 uppercase tracking-wide">Gagal</span>
        <div class="bg-error/10 rounded-lg p-1.5"><i data-lucide="alert-circle" class="w-4 h-4 text-error"></i></div>
      </div>
      <p class="text-2xl font-bold text-base-content">
        <%= typeof failedMessages !== 'undefined' ? failedMessages : '—' %>
      </p>
      <p class="text-xs text-base-content/40 mt-1">pesan gagal hari ini</p>
    </div>
  </div>

  <div class="card bg-base-100 border border-base-300/70 shadow-sm">
    <div class="card-body p-4">
      <div class="flex items-center justify-between mb-2">
        <span class="text-xs font-medium text-base-content/50 uppercase tracking-wide">Uptime</span>
        <div class="bg-indigo-50 rounded-lg p-1.5"><i data-lucide="activity" class="w-4 h-4 text-indigo-500"></i></div>
      </div>
      <p class="text-2xl font-bold text-base-content">
        <%= typeof uptime !== 'undefined' ? uptime : '—' %>
      </p>
      <p class="text-xs text-base-content/40 mt-1">device uptime</p>
    </div>
  </div>

</div>
