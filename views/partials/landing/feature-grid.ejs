<%# landing/feature-grid.ejs %>
<section id="features" class="bg-white py-20">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="text-center max-w-2xl mx-auto mb-14">
      <span class="text-brand-600 text-sm font-semibold uppercase tracking-wider">Fitur Utama</span>
      <h2 class="text-3xl sm:text-4xl font-bold text-base-content mt-2 mb-3">Semua yang Anda Butuhkan</h2>
      <p class="text-base-content/60">Dibangun untuk keandalan, keamanan, dan kemudahan integrasi.</p>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      <div class="card bg-base-50 border border-base-200 hover:shadow-md transition-shadow">
        <div class="card-body gap-3">
          <div class="bg-brand-100 rounded-xl p-3 w-fit"><i data-lucide="smartphone" class="w-6 h-6 text-brand-600"></i></div>
          <h3 class="card-title text-base">Multi-Device Session</h3>
          <p class="text-sm text-base-content/60">Kelola banyak nomor WhatsApp sekaligus dari satu dashboard terpusat.</p>
        </div>
      </div>
      <div class="card bg-base-50 border border-base-200 hover:shadow-md transition-shadow">
        <div class="card-body gap-3">
          <div class="bg-indigo-100 rounded-xl p-3 w-fit"><i data-lucide="users" class="w-6 h-6 text-indigo-600"></i></div>
          <h3 class="card-title text-base">Role-Based Access</h3>
          <p class="text-sm text-base-content/60">Pisahkan akses admin dan operator dengan kontrol penuh di level user management.</p>
        </div>
      </div>
      <div class="card bg-base-50 border border-base-200 hover:shadow-md transition-shadow">
        <div class="card-body gap-3">
          <div class="bg-emerald-100 rounded-xl p-3 w-fit"><i data-lucide="webhook" class="w-6 h-6 text-emerald-600"></i></div>
          <h3 class="card-title text-base">Webhook Terintegrasi</h3>
          <p class="text-sm text-base-content/60">Kirim event pesan ke sistem eksternal seperti n8n, Make, atau endpoint custom Anda.</p>
        </div>
      </div>
      <div class="card bg-base-50 border border-base-200 hover:shadow-md transition-shadow">
        <div class="card-body gap-3">
          <div class="bg-amber-100 rounded-xl p-3 w-fit"><i data-lucide="zap" class="w-6 h-6 text-amber-600"></i></div>
          <h3 class="card-title text-base">REST API Lengkap</h3>
          <p class="text-sm text-base-content/60">Kirim pesan teks, gambar, dokumen, dan audio via API dengan autentikasi API key.</p>
        </div>
      </div>
      <div class="card bg-base-50 border border-base-200 hover:shadow-md transition-shadow">
        <div class="card-body gap-3">
          <div class="bg-rose-100 rounded-xl p-3 w-fit"><i data-lucide="activity" class="w-6 h-6 text-rose-600"></i></div>
          <h3 class="card-title text-base">Monitoring Real-Time</h3>
          <p class="text-sm text-base-content/60">Pantau status koneksi device, antrean pesan, dan log aktivitas secara langsung.</p>
        </div>
      </div>
      <div class="card bg-base-50 border border-base-200 hover:shadow-md transition-shadow">
        <div class="card-body gap-3">
          <div class="bg-sky-100 rounded-xl p-3 w-fit"><i data-lucide="hard-drive" class="w-6 h-6 text-sky-600"></i></div>
          <h3 class="card-title text-base">Self-Hosted</h3>
          <p class="text-sm text-base-content/60">Deploy di server Anda sendiri. Data tidak meninggalkan infrastruktur Anda.</p>
        </div>
      </div>
    </div>
  </div>
</section>
