<%# core/empty-state.ejs — Reusable empty state %>
<%# Param: emptyIcon (lucide icon name, default 'inbox'), emptyTitle, emptyDesc, emptyAction (HTML, opsional) %>

<div class="flex flex-col items-center justify-center py-16 text-center">
  <div class="bg-base-200 rounded-full p-5 mb-4">
    <i data-lucide="<%= typeof emptyIcon !== 'undefined' ? emptyIcon : 'inbox' %>" class="w-10 h-10 text-base-content/30"></i>
  </div>
  <h3 class="font-semibold text-base-content text-lg mb-1">
    <%= typeof emptyTitle !== 'undefined' ? emptyTitle : 'Tidak ada data' %>
  </h3>
  <% if (typeof emptyDesc !== 'undefined' && emptyDesc) { %>
  <p class="text-sm text-base-content/50 max-w-xs mb-4"><%= emptyDesc %></p>
  <% } %>
  <% if (typeof emptyAction !== 'undefined' && emptyAction) { %>
  <%- emptyAction %>
  <% } %>
</div>
