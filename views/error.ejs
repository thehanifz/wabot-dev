<%# error.ejs — Halaman error global (404, 500, dsb.) %>
<%- include('partials/core/head', { title: 'Error ' + (status || 500) + ' — WA-Bot' }) %>

<body class="bg-base-200 min-h-screen flex items-center justify-center font-sans" data-theme="light">

  <div class="flex flex-col items-center text-center max-w-md px-6 gap-6">

    <!-- Icon -->
    <div class="bg-base-100 rounded-2xl p-5 shadow-sm">
      <% if (status === 404) { %>
        <i data-lucide="search-x" class="w-12 h-12 text-base-content/30"></i>
      <% } else if (status === 403) { %>
        <i data-lucide="shield-off" class="w-12 h-12 text-warning/60"></i>
      <% } else { %>
        <i data-lucide="triangle-alert" class="w-12 h-12 text-error/60"></i>
      <% } %>
    </div>

    <!-- Status code -->
    <div>
      <p class="text-7xl font-extrabold text-base-content/10 leading-none tracking-tighter">
        <%= status || 500 %>
      </p>
    </div>

    <!-- Message -->
    <div class="space-y-2">
      <h1 class="text-xl font-semibold text-base-content">
        <% if (status === 404) { %>
          Halaman tidak ditemukan
        <% } else if (status === 403) { %>
          Akses ditolak
        <% } else if (status === 500) { %>
          Terjadi kesalahan server
        <% } else { %>
          Terjadi kesalahan
        <% } %>
      </h1>
      <p class="text-sm text-base-content/50">
        <% if (message) { %>
          <%= message %>
        <% } else if (status === 404) { %>
          Halaman yang Anda cari tidak ada atau telah dipindahkan.
        <% } else if (status === 403) { %>
          Anda tidak memiliki izin untuk mengakses halaman ini.
        <% } else { %>
          Silakan coba beberapa saat lagi atau hubungi administrator.
        <% } %>
      </p>
    </div>

    <!-- Actions -->
    <div class="flex gap-3">
      <a href="javascript:history.back()" class="btn btn-ghost btn-sm gap-2">
        <i data-lucide="arrow-left" class="w-4 h-4"></i>
        Kembali
      </a>
      <a href="/" class="btn btn-primary btn-sm gap-2">
        <i data-lucide="home" class="w-4 h-4"></i>
        Dashboard
      </a>
    </div>

    <!-- Brand footer -->
    <p class="text-xs text-base-content/30">
      WA-Bot &mdash; WhatsApp Gateway Platform
    </p>

  </div>

  <%- include('partials/core/scripts') %>

  <script>
    // Init Lucide icons
    if (typeof lucide !== 'undefined') lucide.createIcons();
  </script>

</body>
</html>
