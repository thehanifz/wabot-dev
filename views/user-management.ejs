<!DOCTYPE html>
<html lang="id" data-theme="wabot">
<head>
  <%- include('partials/core/head', { title: 'User Management' }) %>
</head>
<body class="bg-base-200 min-h-screen">
<div class="drawer lg:drawer-open">
  <input id="app-drawer" type="checkbox" class="drawer-toggle" />

  <div class="drawer-content flex flex-col min-h-screen">
    <%- include('partials/nav/topbar-app') %>

    <main class="flex-1 max-w-6xl mx-auto w-full px-4 sm:px-6 py-6">
      <%- include('partials/core/flash-alert') %>
      <%- include('partials/core/page-header', {
        pageTitle: 'User Management',
        pageSubtitle: 'Kelola akses dan role pengguna.',
        pageAction: '<a href="/admin/users/new" class="btn btn-sm btn-primary gap-2"><i data-lucide="user-plus" class="w-4 h-4"></i>Tambah User</a>'
      }) %>

      <div class="card bg-base-100 border border-base-300/70 shadow-sm">
        <div class="card-body p-5">

          <!-- Filter row -->
          <div class="flex flex-col sm:flex-row sm:items-center gap-3 mb-5"
               x-data="{ search: '', filterRole: '', filterStatus: '' }">
            <div class="join flex-1">
              <input type="text" x-model="search"
                     class="input input-sm input-bordered join-item flex-1"
                     placeholder="Cari nama atau email..." />
              <button class="btn btn-sm btn-ghost join-item border border-base-300">
                <i data-lucide="search" class="w-4 h-4"></i>
              </button>
            </div>
            <div class="flex gap-2">
              <select x-model="filterRole" class="select select-sm select-bordered">
                <option value="">Semua Role</option>
                <option value="admin">Admin</option>
                <option value="user">User</option>
              </select>
              <select x-model="filterStatus" class="select select-sm select-bordered">
                <option value="">Semua Status</option>
                <option value="active">Active</option>
                <option value="suspended">Suspended</option>
              </select>
            </div>
          </div>

          <!-- Tabel user -->
          <div class="overflow-x-auto">
            <table class="table table-sm">
              <thead>
                <tr class="text-xs text-base-content/50">
                  <th>Pengguna</th>
                  <th>Role</th>
                  <th>Status</th>
                  <th>Bergabung</th>
                  <th class="text-right">Aksi</th>
                </tr>
              </thead>
              <tbody>
                <% if (typeof users !== 'undefined' && users.length > 0) { %>
                  <% users.forEach(u => { %>
                  <tr class="hover:bg-base-50">
                    <td>
                      <div class="flex items-center gap-3">
                        <div class="avatar placeholder shrink-0">
                          <div class="bg-brand-100 text-brand-700 rounded-full w-8">
                            <span class="text-xs font-bold"><%= u.displayName ? u.displayName.charAt(0).toUpperCase() : 'U' %></span>
                          </div>
                        </div>
                        <div>
                          <div class="font-medium text-sm text-base-content"><%= u.displayName %></div>
                          <div class="text-xs text-base-content/40"><%= u.email %></div>
                        </div>
                      </div>
                    </td>
                    <td>
                      <span class="badge badge-sm <%= u.role === 'admin' ? 'badge-primary' : 'badge-ghost' %>">
                        <%= u.role %>
                      </span>
                    </td>
                    <td>
                      <span class="badge badge-sm <%= u.isActive ? 'badge-success' : 'badge-error' %>">
                        <%= u.isActive ? 'Active' : 'Suspended' %>
                      </span>
                    </td>
                    <td class="text-xs text-base-content/50">
                      <%= u.createdAt ? new Date(u.createdAt).toLocaleDateString('id-ID') : '—' %>
                    </td>
                    <td class="text-right">
                      <div class="flex justify-end gap-1">
                        <a href="/admin/users/<%= u.id %>/edit"
                           class="btn btn-ghost btn-xs gap-1">
                          <i data-lucide="pencil" class="w-3.5 h-3.5"></i> Edit
                        </a>
                        <button
                          class="btn btn-ghost btn-xs gap-1 text-error"
                          @click="$dispatch('open-confirm-modal', {
                            title: 'Hapus Pengguna',
                            message: 'Aksi ini tidak dapat dibatalkan. Yakin ingin menghapus <%= u.displayName %>?',
                            confirmLabel: 'Ya, Hapus',
                            onConfirm: () => { window.location.href = '/admin/users/<%= u.id %>/delete' }
                          })">
                          <i data-lucide="trash-2" class="w-3.5 h-3.5"></i> Hapus
                        </button>
                      </div>
                    </td>
                  </tr>
                  <% }) %>
                <% } else { %>
                <tr>
                  <td colspan="5">
                    <%- include('partials/core/empty-state', {
                      emptyIcon: 'users',
                      emptyTitle: 'Belum ada pengguna',
                      emptyDesc: 'Tambahkan pengguna pertama untuk mulai mengatur akses.'
                    }) %>
                  </td>
                </tr>
                <% } %>
              </tbody>
            </table>
          </div>

        </div>
      </div>

      <%- include('partials/core/confirm-modal') %>
    </main>
  </div>

  <div class="drawer-side z-40">
    <label for="app-drawer" aria-label="close sidebar" class="drawer-overlay"></label>
    <%- include('partials/nav/sidebar-admin') %>
  </div>
</div>
<%- include('partials/core/scripts', { loadSocketIO: true }) %>
</body>
</html>
