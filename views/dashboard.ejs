<!DOCTYPE html>
<html lang="id" data-theme="wabot">
<head>
  <%- include('partials/core/head', { title: 'Dashboard' }) %>
</head>
<body class="bg-base-200 min-h-screen">
<div class="drawer lg:drawer-open">
  <input id="app-drawer" type="checkbox" class="drawer-toggle" />

  <div class="drawer-content flex flex-col min-h-screen">
    <%- include('partials/nav/topbar-app') %>

    <main class="flex-1 max-w-6xl mx-auto w-full px-4 sm:px-6 py-6">
      <%- include('partials/core/flash-alert') %>
      <%- include('partials/core/page-header', {
        pageTitle: 'Dashboard',
        pageSubtitle: 'Ringkasan aktivitas dan device Anda.'
      }) %>

      <!-- KPI Cards -->
      <%- include('partials/dashboard-user/kpi-cards') %>

      <!-- Device Table -->
      <div class="mt-6">
        <%- include('partials/dashboard-user/device-table') %>
      </div>

      <!-- Bottom row: activity + quick actions -->
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mt-6">
        <div class="lg:col-span-2">
          <%- include('partials/dashboard-user/recent-activity') %>
        </div>
        <div>
          <%- include('partials/dashboard-user/quick-actions') %>
        </div>
      </div>
    </main>
  </div>

  <div class="drawer-side z-40">
    <label for="app-drawer" aria-label="close sidebar" class="drawer-overlay"></label>
    <%- include('partials/nav/sidebar-user') %>
  </div>
</div>
<%- include('partials/core/scripts', { loadSocketIO: true }) %>
</body>
</html>
